FROM ubuntu:25.04

RUN export DEBIAN_FRONTEND=noninteractive && apt-get update && \
    apt-get install -y \
    casacore-dev \
    cmake \
    g++ \
    git \
    pkg-config \
    libblas-dev \
    libboost-filesystem-dev \
    libboost-program-options-dev \
    libcfitsio-dev \
    libfftw3-dev \
    libgsl-dev \
    libhdf5-dev \
    liblapack-dev \
    libopenmpi-dev \
    libpython3-dev \
    pybind11-dev \
    pkg-config

ADD . /src
WORKDIR /src

RUN \
  mkdir /build && \
  cd /build && \
  cmake ../src && \
  make -j`nproc` && \
  make install && \
  wsclean --version
